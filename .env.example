PORT=5432
PATCH_SCHEDULE=0 2 * * *
PATCH_CONCURRENCY=3
COPA_TIMEOUT=10m
COPA_VERSION=0.14.1
# sha256 of copa_<COPA_VERSION>_linux_<arch>.tar.gz from copacetic_checksums.txt
# on the GitHub release — update together with COPA_VERSION.
# 0.14.1 linux_amd64: a780f62c054f60cd1aecbbf4a4b2665a816aa852534e6b0b9592cf96a327fdc9
# 0.14.1 linux_arm64: dad5ee9b8ad19ed63c87242e68cc1739dffbef07928faf3eb7cfdfa48ef2c2c7
COPA_SHA256=a780f62c054f60cd1aecbbf4a4b2665a816aa852534e6b0b9592cf96a327fdc9
TRIVY_IMAGE=aquasec/trivy:0.71.0
TRIVY_CACHE_VOLUME=trivy-db-cache
BUILDKIT_VERSION=v0.30.0
# GID of the host Docker socket group, so the non-root container user can use
# the daemon. Find it with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999
# Comma-separated registries that POST /images accepts (e.g. docker.io,ghcr.io).
# Leave empty to accept any registry (a warning is logged at startup).
ALLOWED_REGISTRIES=docker.io
# Set to false to disable the Swagger UI at /docs
ENABLE_DOCS=true
